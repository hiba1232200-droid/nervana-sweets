# ─── Database ────────────────────────────────────────────────
# Local Postgres (docker-compose provides this automatically):
DATABASE_URL="postgresql://nervana:nervana@localhost:5432/nervana?schema=public"

# ─── NextAuth ────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# App-level JWT for the REST API (jose)
JWT_SECRET="change-me-too-another-long-random-string"

# ─── OAuth (Google login) ────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Security ────────────────────────────────────────────────
# reCAPTCHA v3 (login CAPTCHA). Leave blank to disable in dev.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Optional: Upstash Redis for distributed rate-limiting (falls back to in-memory)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Email (SMTP) — leave blank to log emails to the console in dev ──
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="NERVANA <no-reply@nervana.sweets>"

# ─── SMS / OTP (Twilio) — leave blank to log OTP codes to the console ──
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# ─── Admin ───────────────────────────────────────────────────
# Secret dashboard slug — must match ADMIN_PATH in lib/admin/config.ts
ADMIN_PATH="/control-a7x92k"

# ─── Telegram bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""
# Secret checked on the webhook (X-Telegram-Bot-Api-Secret-Token)
TELEGRAM_WEBHOOK_SECRET="change-me-telegram-secret"

# ─── Exchange rate ───────────────────────────────────────────
# Provider that returns USD→SYP. Defaults to open.er-api.com (free, no key).
EXCHANGE_RATE_URL="https://open.er-api.com/v6/latest/USD"
# Protects cron endpoints (Authorization: Bearer <secret>)
CRON_SECRET="change-me-cron-secret"

# Telegram channel that publishes the live USD→SYP rate.
# Add your bot as an ADMIN of this channel so channel posts reach the webhook.
TELEGRAM_RATE_CHANNEL="@SaymouaaExchange"
# Sanity bounds for a parsed USD→SYP rate (reject values outside this range).
EXCHANGE_MIN="1000"
EXCHANGE_MAX="1000000"
# Max % jump vs. the last rate before a parsed value is flagged (0 = disabled).
EXCHANGE_MAX_JUMP="0.4"

# ─── Web Push (VAPID) — generate: npx web-push generate-vapid-keys ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@nervana.sweets"

# ─── AI assistant (optional) — falls back to on-site catalogue AI ──
AI_PROVIDER="" # "openai" | "anthropic" | "" (local)
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"

# ─── Public ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="963900000000"
